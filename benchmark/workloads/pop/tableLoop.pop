namespace BenchmarkArrayLoop

function main()
    local values = Array.create<<Int>>(1000000, 0)
    local length = Array.length(values)
    local index = 1
    repeat
        values[index] = index
        index = index + 1
    until index == 1000001

    index = 1
    local total = 0
    repeat
        total = total + Array.get(values, index)
        index = index + 1
    until index == length + 1
    print(total)
end
