            </section>

            <section class="kpis" aria-label="Summary">
              <article class="kpi"><div class="kpi-label">Fastest</div><div class="kpi-value" id="winner">—</div><div class="kpi-detail" id="winner-time">—</div></article>
              <article class="kpi"><div class="kpi-label">Pop vs fastest rival</div><div class="kpi-value" id="pop-speedup">—</div><div class="kpi-detail" id="pop-detail">—</div></article>
              <article class="kpi"><div class="kpi-label">Measured spread</div><div class="kpi-value" id="spread">—</div><div class="kpi-detail">slowest comparable median ÷ fastest</div></article>
            </section>

            <section class="panel">
              <div class="panel-head"><div><h2>Live speed lanes</h2><p id="workload-description">Choose a workload to compare runtimes.</p></div><div class="axis-note">middle line = halfway · logarithmic timing keeps wide gaps readable</div></div>
              <div class="comparison-chart" id="ranking" aria-live="polite"></div>
              <div class="excluded" id="excluded"></div>
            </section>

            <section class="panel">
              <div class="panel-head"><div><h2>Sample distribution</h2><p>Every measured process execution, not just one flattering number.</p></div></div>
              <div class="table-wrap"><table class="distribution-table"><thead><tr><th>Runtime</th><th>Minimum</th><th>Median</th><th>Maximum</th><th>Variation</th><th>Samples</th></tr></thead><tbody id="distribution"></tbody></table></div>
            </section>
            <p class="footnote">Compilation and provisioning happen before timing. Results include process startup and output. Entries marked non-comparable are shown as diagnostics but never ranked.</p>
          </main>
          <script>
            const documentData=#{payload};
            const colors={poplang:'#42d8f5',ruby:'#cc342d',go:'#00add8',c:'#a8b9cc',d:'#b03931',csharp:'#8b5cf6',crystal:'#d8dee9',lua:'#4c66d6',luajit:'#7656df',luau:'#38bdf8',luaujit:'#22d3ee'};
            const $=selector=>document.querySelector(selector);
            const element=(tag,className,text)=>{const node=document.createElement(tag);if(className)node.className=className;if(text!==undefined)node.textContent=text;return node};
            const resultWorkloads=[...new Map(documentData.results.map(row=>[row.workload,{id:row.workload,name:row.workloadName,description:''}])).values()];
            const workloads=(documentData.workloads?.length?documentData.workloads:resultWorkloads);
            const workloadById=new Map(workloads.map(workload=>[workload.id,workload]));
            const chooser=$('#workload'),metric=$('#metric');
            workloads.forEach(workload=>chooser.add(new Option(workload.name,workload.id)));
            $('#run-date').textContent=new Date(documentData.createdAt).toLocaleString();
            $('#sample-count').textContent=String(documentData.samples);
            $('#schema').textContent=String(documentData.schemaVersion);

            function time(seconds){if(seconds<.001)return `${(seconds*1e6).toFixed(1)} µs`;if(seconds<1)return `${(seconds*1e3).toFixed(seconds<.01?2:1)} ms`;return `${seconds.toFixed(3)} s`}
            function icon(row){const image=element('img','language-icon');image.alt='';image.src=documentData.icons?.[row.runtime]||'';return image}
            function languageCell(row){const wrap=element('div','language');wrap.append(icon(row));const copy=element('div');copy.append(element('div','language-name',row.runtimeName));copy.append(element('small','language-mode',row.executionModel||'runtime'));wrap.append(copy);return wrap}
            function comparable(row){return row.comparable!==false}

            function draw(){
              const key=metric.value;
              const all=documentData.results.filter(row=>row.workload===chooser.value);
              const rows=all.filter(comparable).sort((left,right)=>left[key]-right[key]);
              const skipped=all.filter(row=>!comparable(row));
              const ranking=$('#ranking'),excluded=$('#excluded'),distribution=$('#distribution');
              ranking.replaceChildren();excluded.replaceChildren();distribution.replaceChildren();
              const metadata=workloadById.get(chooser.value);
              $('#workload-description').textContent=metadata?.description||'';
              if(!rows.length){ranking.append(element('div','empty','No comparable results for this workload.'));return}
              const fastest=rows[0][key],slowest=rows.at(-1)[key];
              rows.forEach((row,index)=>{
                const item=element('article',`bar-row${index===0?' winner':''}`);item.style.setProperty('--language',colors[row.runtime]||'#94a3b8');
                item.append(languageCell(row));
                const zone=element('div','race-track'),progress=element('div','race-progress'),runner=element('div','racer');const ratio=row[key]/fastest;progress.style.setProperty('--race-duration',`${(.85+Math.log2(Math.max(1,ratio))*1.15).toFixed(2)}s`);progress.style.setProperty('--finish',`${Math.max(2,fastest/row[key]*100)}%`);progress.title=`${ratio.toFixed(2)}× the fastest time`;runner.append(icon(row));progress.append(runner);zone.append(progress);item.append(zone);
                const value=element('div','bar-value');value.append(element('strong','',time(row[key])));value.append(element('small','',index===0?'baseline':`${(row[key]/fastest).toFixed(2)}× time`));item.append(value);ranking.append(item);
              });
              skipped.forEach(row=>excluded.append(element('div','excluded-item',`${row.runtimeName}: ${row.comparisonNote||'excluded from this ranking'}`)));

              $('#winner').textContent=rows[0].runtimeName;$('#winner-time').textContent=`${time(fastest)} ${key==='medianSeconds'?'median':'minimum'}`;$('#spread').textContent=`${(slowest/fastest).toFixed(1)}×`;
              const pop=rows.find(row=>row.runtime==='poplang'),rival=rows.find(row=>row.runtime!=='poplang');
              if(pop&&rival){const ratio=rival[key]/pop[key];$('#pop-speedup').textContent=ratio>=1?`${ratio.toFixed(2)}× faster`:`${(1/ratio).toFixed(2)}× slower`;$('#pop-detail').textContent=`against ${rival.runtimeName}`}
              else{$('#pop-speedup').textContent='—';$('#pop-detail').textContent='Pop or a rival is missing'}

              rows.forEach(row=>{
                const samples=row.samplesSeconds||[];const minimum=Math.min(...samples),maximum=Math.max(...samples),median=row.medianSeconds;const tr=element('tr');
                const runtime=element('td');runtime.append(languageCell(row));tr.append(runtime);
                [time(minimum),time(median),time(maximum),`${median?((maximum-minimum)/median*100).toFixed(1):'0.0'}%`].forEach(value=>tr.append(element('td','',value)));
                const plotCell=element('td'),plot=element('div','sample-line');plot.style.setProperty('--dot',colors[row.runtime]||'#94a3b8');const range=maximum-minimum||1;
                samples.forEach(sample=>{const dot=element('span','sample-dot');dot.style.left=`${(sample-minimum)/range*100}%`;dot.title=time(sample);plot.append(dot)});plotCell.append(plot);tr.append(plotCell);distribution.append(tr);
              });
            }
            chooser.addEventListener('change',draw);metric.addEventListener('change',draw);
            $('#theme').addEventListener('click',()=>{const root=document.documentElement;root.dataset.theme=root.dataset.theme==='light'?'dark':'light'});
            draw();
          </script>
        </body>
        </html>
      HTML
    end

    def embedded_icons(document)
      document.fetch("results", []).to_h do |result|
        runtime = result.fetch("runtime")
        [runtime, icon_data(runtime)]
      end
    end

    def icon_data(runtime)
      filename = case runtime
      when "poplang" then File.join(ROOT, "assets", "pop.svg")
      when "ruby" then File.join(DIRECTORY, "assets", "icons", "ruby.svg")
      when "go" then File.join(DIRECTORY, "assets", "icons", "go.svg")
      when "c" then File.join(DIRECTORY, "assets", "icons", "c.svg")
      when "d" then File.join(DIRECTORY, "assets", "icons", "d.svg")
      when "csharp" then File.join(DIRECTORY, "assets", "icons", "dotnet.svg")
      when "crystal" then File.join(DIRECTORY, "assets", "icons", "crystal.svg")
      when "lua", "luajit", "luau", "luaujit" then File.join(DIRECTORY, "assets", "icons", "lua.svg")
      end
      return "" unless filename && File.file?(filename)

      "data:image/svg+xml;base64,#{[File.binread(filename)].pack("m0")}"
    end
  end

  module Cli
    module_function

    def call(arguments)
      command = arguments.shift || "run"
      case command
      when "list" then puts JSON.pretty_generate("runtimes" => REGISTRY.runtimes.map { |item| { "id" => item.id, "name" => item.name } }, "workloads" => REGISTRY.workloads.map { |item| { "id" => item.id, "name" => item.name } })
      when "provision" then provision(arguments)
      when "run" then run(arguments)
      when "render" then render(arguments)
      else raise "usage: benchmark [list|provision|run|render]"
      end
    rescue StandardError => error
      warn "benchmark: #{error.message}"
      exit 1
    end

    def provision(arguments)
      selected = arguments.empty? ? REGISTRY.runtimes : REGISTRY.runtimes.select { |runtime| arguments.include?(runtime.id) }
      raise "unknown runtime" if selected.empty?
      selected.each { |runtime| Provision.runtime(runtime); puts "ready: #{runtime.id}" }
    end

    def run(arguments)
      options = { samples: 7, warmups: 2, runtimes: [], workloads: [], output: File.join(RESULT_DIRECTORY, "latest.json") }
      OptionParser.new { |parser| parser.on("--samples NUMBER", Integer) { |value| options[:samples] = value }; parser.on("--warmups NUMBER", Integer) { |value| options[:warmups] = value }; parser.on("--runtime NAME") { |value| options[:runtimes] << value }; parser.on("--workload NAME") { |value| options[:workloads] << value }; parser.on("--output PATH") { |value| options[:output] = value } }.parse!(arguments)
      document = Runner.new(samples: options[:samples], warmups: options[:warmups], selected_runtimes: options[:runtimes], selected_workloads: options[:workloads]).run
      FileUtils.mkdir_p(File.dirname(options[:output]))
      File.write(options[:output], JSON.pretty_generate(document) + "\n")
      puts options[:output]
    end

    def render(arguments)
      options = { output: File.join(RESULT_DIRECTORY, "latest.html") }
      OptionParser.new { |parser| parser.on("--input PATH") { |value| options[:input] = value }; parser.on("--output PATH") { |value| options[:output] = value } }.parse!(arguments)
      raise "render requires --input RESULTS.json" unless options[:input]
      FileUtils.mkdir_p(File.dirname(options[:output]))
      File.write(options[:output], Report.render(JSON.parse(File.read(options[:input]))))
      puts options[:output]
    end
  end
end

PopBenchmark::Cli.call(ARGV) if $PROGRAM_NAME == __FILE__
