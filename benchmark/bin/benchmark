#!/usr/bin/env ruby
# frozen_string_literal: true

require "benchmark"
require "digest"
require "fileutils"
require "json"
require "open3"
require "optparse"
require "rbconfig"
require "shellwords"
require "time"

# A small DSL keeps the benchmark matrix declarative while the runner owns the
# common provisioning, timing, result, and report behavior.
module PopBenchmark
  ROOT = File.expand_path("../..", __dir__)
  DIRECTORY = File.join(ROOT, "benchmark")
  TOOL_DIRECTORY = File.join(DIRECTORY, ".tools")
  RESULT_DIRECTORY = File.join(DIRECTORY, "results")
  LDC_VERSION = "1.42.0"
  LDC_LINUX_SHA256 = "a7bc9c956138f558cadf9c962352f59d41c80df6eb3ae3f8039f25be14a69303"

  Runtime = Data.define(:id, :name, :source_directory, :source_extension, :command, :provisioner, :builder, :mode)
  Workload = Data.define(:id, :name, :description)

  class Registry
    attr_reader :runtimes, :workloads

    def initialize
      @runtimes = []
      @workloads = []
    end

    def runtime(id, name:, extension:, command:, provisioner:, builder: nil, mode: "interpreted", directory: extension)
      @runtimes << Runtime.new(id, name, directory, extension, command, provisioner, builder, mode)
    end

    def workload(id, name:, description:)
      @workloads << Workload.new(id, name, description)
    end
  end

  REGISTRY = Registry.new
  REGISTRY.instance_eval do
    runtime "lua", name: "Lua 5.5.0", extension: "lua", command: ->(source, _) { [File.join(TOOL_DIRECTORY, "lua", "bin", "lua"), source] }, provisioner: :lua
    runtime "luajit", name: "LuaJIT 2.1", extension: "lua", command: ->(source, _) { [File.join(TOOL_DIRECTORY, "luajit", "bin", "luajit-2.1.0-beta3"), source] }, provisioner: :luajit, mode: "JIT"
    runtime "luau", name: "Luau 0.729", extension: "luau", command: ->(source, _) { [File.join(TOOL_DIRECTORY, "luau", "luau"), source] }, provisioner: :luau
    runtime "luaujit", name: "Luau 0.729 native codegen", extension: "luau", command: ->(source, _) { [File.join(TOOL_DIRECTORY, "luaujit", "luau"), "--codegen", source] }, provisioner: :luaujit, mode: "native JIT"
    runtime "ruby", name: "Ruby 3.4", extension: "rb", directory: "ruby", command: ->(source, _) { [RbConfig.ruby, source] }, provisioner: :ruby
    runtime "go", name: "Go 1.26", extension: "go", command: ->(_, artifact) { [artifact] }, provisioner: :go, builder: :go, mode: "ahead of time"
    runtime "c", name: "C · Clang 22 -O3", extension: "c", command: ->(_, artifact) { [artifact] }, provisioner: :c, builder: :c, mode: "ahead of time"
    runtime "d", name: "D · LDC 1.42 -O3", extension: "d", command: ->(_, artifact) { [artifact] }, provisioner: :ldc, builder: :d, mode: "ahead of time"
    runtime "csharp", name: "C# · .NET 10", extension: "cs", directory: "csharp", command: ->(_, artifact) { [artifact] }, provisioner: :csharp, builder: :csharp, mode: "tiered JIT"
    runtime "crystal", name: "Crystal 1.20 · release", extension: "cr", directory: "crystal", command: ->(_, artifact) { [artifact] }, provisioner: :crystal, builder: :crystal, mode: "ahead of time"
    runtime "poplang", name: "Pop Lang · LLVM O3", extension: "pop", command: ->(_, artifact) { [artifact] }, provisioner: :poplang, builder: :poplang, mode: "ahead of time"

    workload "fibonacci", name: "Recursive Fibonacci", description: "Repeated recursive integer calls; prints a checksum."
    workload "integerLoop", name: "Integer loop", description: "Integer arithmetic in a counted loop; prints a checksum."
    workload "tableLoop", name: "Array loop", description: "Builds and sums a numeric collection; prints a checksum."
  end

  module Command
    module_function

    def run(*arguments, chdir: ROOT, environment: {})
      output, status = Open3.capture2e(environment, *arguments, chdir: chdir)
      raise "command failed (#{Shellwords.join(arguments)}):\n#{output}" unless status.success?
      output
    end

    def download(url, output)
      FileUtils.mkdir_p(File.dirname(output))
      run("curl", "--fail", "--location", "--retry", "3", "--output", output, url)
    end
  end

  module Provision
    module_function

    def runtime(runtime)
      send(runtime.provisioner)
    end

    def host
      @host ||= begin
        cpu = RbConfig::CONFIG.fetch("host_cpu")
        os = RbConfig::CONFIG.fetch("host_os")
        raise "only x86_64 hosts are currently supported" unless cpu.match?(/x86_64|amd64/)
        os.match?(/darwin/) ? :macos : (os.match?(/linux/) ? :linux : raise("unsupported host #{os}"))
      end
    end

    def archive(url, name)
      path = File.join(TOOL_DIRECTORY, "downloads", name)
      Command.download(url, path) unless File.file?(path)
      path
    end

    def lua
      executable = File.join(TOOL_DIRECTORY, "lua", "bin", "lua")
      return if File.executable?(executable)
      source = archive("https://www.lua.org/ftp/lua-5.5.0.tar.gz", "lua-5.5.0.tar.gz")
      build_source("lua", source, "lua-5.5.0") do |directory, prefix|
        target = host == :macos ? "macosx" : "linux"
        Command.run("make", target, "MYCFLAGS=-O3 -fPIC", "INSTALL_TOP=#{prefix}", chdir: directory)
        Command.run("make", "install", "INSTALL_TOP=#{prefix}", chdir: directory)
      end
    end

    def luajit
      executable = File.join(TOOL_DIRECTORY, "luajit", "bin", "luajit-2.1.0-beta3")
      return if File.executable?(executable)
      source = archive("https://github.com/LuaJIT/LuaJIT/archive/refs/tags/v2.1.0-beta3.tar.gz", "luajit-2.1.0-beta3.tar.gz")
      build_source("luajit", source, "LuaJIT-2.1.0-beta3") do |directory, prefix|
        Command.run("make", "amalg", "XCFLAGS=-O3 -fPIC", chdir: directory)
        Command.run("make", "install", "PREFIX=#{prefix}", chdir: directory)
      end
    end

    def luau
      luau_release("luau", codegen: false)
    end

    def luaujit
      luau_release("luaujit", codegen: true)
    end

    def luau_release(name, codegen:)
      executable = File.join(TOOL_DIRECTORY, name, "luau")
      return if File.executable?(executable)
      asset = host == :macos ? "luau-macos.zip" : "luau-ubuntu.zip"
      source = archive("https://github.com/luau-lang/luau/releases/download/0.729/#{asset}", "luau-0.729-#{asset}")
      stage = File.join(TOOL_DIRECTORY, ".stage-#{name}")
      FileUtils.rm_rf(stage)
      FileUtils.mkdir_p(stage)
      Command.run("unzip", "-q", source, "-d", stage)
      found = Dir.glob(File.join(stage, "**", "luau")).find { |path| File.file?(path) }
      raise "Luau archive does not contain a luau executable" unless found
      FileUtils.mkdir_p(File.dirname(executable))
      FileUtils.cp(found, executable)
      FileUtils.chmod("u+x", executable)
      return unless codegen
      help = Command.run(executable, "--help")
      raise "Luau 0.729 does not expose --codegen on this host" unless help.include?("--codegen")
    ensure
      FileUtils.rm_rf(stage) if defined?(stage) && stage
    end

    def poplang
      executable = File.join(ROOT, "target", "release", "pop")
      return if File.executable?(executable)
      Command.run("cargo", "build", "--release", "--package", "pop-driver", "--bin", "pop")
    end

    def ruby
      require_tool(RbConfig.ruby, "--version")
    end

    def go
      require_tool("go", "version")
    end

    def c
      require_tool("clang", "--version")
    end

    def csharp
      require_tool("dotnet", "--version")
    end

    def crystal
      require_tool("crystal", "--version")
    end

    def ldc
      executable = File.join(TOOL_DIRECTORY, "ldc", "bin", "ldc2")
      return if File.executable?(executable)
      raise "automatic LDC provisioning currently supports Linux x86_64" unless host == :linux

      filename = "ldc2-#{LDC_VERSION}-linux-x86_64.tar.xz"
      source = archive(
        "https://github.com/ldc-developers/ldc/releases/download/v#{LDC_VERSION}/#{filename}",
        filename
      )
      actual = Digest::SHA256.file(source).hexdigest
      raise "LDC archive checksum mismatch: #{actual}" unless actual == LDC_LINUX_SHA256

      stage = File.join(TOOL_DIRECTORY, ".stage-ldc")
      FileUtils.rm_rf(stage)
      FileUtils.mkdir_p(stage)
      Command.run("tar", "-xJf", source, "-C", stage)
      root = File.join(stage, "ldc2-#{LDC_VERSION}-linux-x86_64")
      raise "LDC archive has an unexpected layout" unless File.executable?(File.join(root, "bin", "ldc2"))
      FileUtils.rm_rf(File.join(TOOL_DIRECTORY, "ldc"))
      FileUtils.cp_r(root, File.join(TOOL_DIRECTORY, "ldc"))
    ensure
      FileUtils.rm_rf(stage) if defined?(stage) && stage
    end

    def require_tool(command, *arguments)
      Command.run(command, *arguments)
    rescue Errno::ENOENT
      raise "required tool is not installed: #{command}"
    end

    def build_source(name, archive_path, source_directory)
      prefix = File.join(TOOL_DIRECTORY, name)
      stage = File.join(TOOL_DIRECTORY, ".stage-#{name}")
      FileUtils.rm_rf(stage)
      FileUtils.mkdir_p(stage)
      Command.run("tar", "-xzf", archive_path, "-C", stage)
      yield File.join(stage, source_directory), prefix
    ensure
      FileUtils.rm_rf(stage) if defined?(stage) && stage
    end
  end

  module Build
    module_function

    def prepare(runtime, workload, source)
      return unless runtime.builder

      directory = File.join(TOOL_DIRECTORY, "artifacts", runtime.id, workload.id)
      FileUtils.mkdir_p(directory)
      send(runtime.builder, source, directory)
    end

    def poplang(source, directory)
      executable = File.join(directory, "benchmark")
      Command.run(File.join(ROOT, "target", "release", "pop"), "build", source, "--output", executable)
      executable
    end

    def go(source, directory)
      executable = File.join(directory, "benchmark")
      Command.run("go", "build", "-trimpath", "-ldflags=-s -w", "-o", executable, source)
      executable
    end

    def c(source, directory)
      executable = File.join(directory, "benchmark")
      Command.run("clang", "-std=c17", "-O3", "-march=native", source, "-o", executable)
      executable
    end

    def d(source, directory)
      executable = File.join(directory, "benchmark")
      compiler = File.join(TOOL_DIRECTORY, "ldc", "bin", "ldc2")
      Command.run(compiler, "-O3", "-release", "-mcpu=native", source, "-of=#{executable}")
      executable
    end

    def csharp(source, directory)
      project = File.join(DIRECTORY, "workloads", "csharp", "Benchmark.csproj")
      intermediate = File.join(TOOL_DIRECTORY, "csharp", "obj", File.basename(source, ".cs"))
      Command.run(
        "dotnet", "build", project,
        "--configuration", "Release",
        "--output", directory,
        "-p:BenchmarkSource=#{source}",
        "-p:BaseIntermediateOutputPath=#{intermediate}/"
      )
      executable = File.join(directory, "PopBenchmark")
      raise "C# build did not emit an executable" unless File.executable?(executable)
      executable
    end

    def crystal(source, directory)
      executable = File.join(directory, "benchmark")
      cache = File.join(TOOL_DIRECTORY, "crystal", "cache")
      FileUtils.mkdir_p(cache)
      Command.run(
        "crystal", "build", "--release", "--mcpu", "native", source, "-o", executable,
        environment: { "CRYSTAL_CACHE_DIR" => cache }
      )
      executable
    end
  end

  class Runner
    def initialize(samples:, warmups:, selected_runtimes:, selected_workloads:)
      @samples, @warmups = samples, warmups
      @runtimes = filter(REGISTRY.runtimes, selected_runtimes)
      @workloads = filter(REGISTRY.workloads, selected_workloads)
    end

    def run
      available = @runtimes.select { |runtime| provision(runtime) }
      prepared = available.product(@workloads).filter_map do |runtime, workload|
        begin
          [runtime, workload, prepare_command(runtime, workload)]
        rescue StandardError => error
          warn "benchmark: skipping #{runtime.id}/#{workload.id}: #{error.message.lines.first.strip}"
          nil
        end
      end
      measurements = prepared.flat_map do |runtime, workload, command|
        begin
          @warmups.times { execute(command) }
          times = @samples.times.map { execute(command) }
          result(runtime, workload, times)
        rescue StandardError => error
          warn "benchmark: skipping #{runtime.id}/#{workload.id}: #{error.message.lines.first.strip}"
          []
        end
      end
      {
        "schemaVersion" => 2,
        "createdAt" => Time.now.utc.iso8601,
        "samples" => @samples,
        "warmups" => @warmups,
        "timing" => "execution only; provisioning and compilation are excluded",
        "workloads" => @workloads.map { |workload| { "id" => workload.id, "name" => workload.name, "description" => workload.description } },
        "results" => measurements
      }
    end

    private

    def filter(items, selected)
      return items if selected.empty?
      items.select { |item| selected.include?(item.id) }.tap { |value| raise "nothing matched #{selected.join(", ")}" if value.empty? }
    end

    def source_path(runtime, workload)
      path = File.join(DIRECTORY, "workloads", runtime.source_directory, "#{workload.id}.#{runtime.source_extension}")
      raise "missing workload #{path}" unless File.file?(path)
      path
    end

    def prepare_command(runtime, workload)
      source = source_path(runtime, workload)
      artifact = Build.prepare(runtime, workload, source)
      runtime.command.call(source, artifact)
    end

    def provision(runtime)
      @workloads.each { |workload| source_path(runtime, workload) }
      Provision.runtime(runtime)
      true
    rescue StandardError => error
      warn "benchmark: skipping #{runtime.id}: #{error.message.lines.first.strip}"
      false
    end

    def execute(command)
      started = Process.clock_gettime(Process::CLOCK_MONOTONIC)
      Command.run(*command)
      Process.clock_gettime(Process::CLOCK_MONOTONIC) - started
    end

    def result(runtime, workload, times)
      sorted = times.sort
      comparable = true

      result = {
        "runtime" => runtime.id,
        "runtimeName" => runtime.name,
        "executionModel" => runtime.mode,
        "workload" => workload.id,
        "workloadName" => workload.name,
        "samplesSeconds" => times,
        "medianSeconds" => sorted[times.length / 2],
        "minimumSeconds" => sorted.first,
        "comparable" => comparable
      }

      result
    end
  end

  module Report
    module_function

    def render(document)
      document = document.merge("icons" => embedded_icons(document))
      payload = JSON.generate(document)
        .gsub("<", "\\u003c")
        .gsub("\u2028", "\\u2028")
        .gsub("\u2029", "\\u2029")
      <<~HTML
