namespace Pop.Sequence

private class MappingIterator<T, U> implements Iterator<U>
    private source: Iterator<T>
    private transform: function(value: T): U

    public function MappingIterator.new(source: Iterator<T>, transform: function(value: T): U): MappingIterator<T, U>
        return MappingIterator { source = source, transform = transform }
    end

    public function MappingIterator:iterator(): Iterator<U>
        return self
    end

    public function MappingIterator:next(): Iteration<U>
        for value in self.source do
            return Iteration.Item(self.transform(value))
        end
        return Iteration.End
    end
end

private class FilteringIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private predicate: function(value: T): Boolean

    public function FilteringIterator.new(source: Iterator<T>, predicate: function(value: T): Boolean): FilteringIterator<T>
        return FilteringIterator { source = source, predicate = predicate }
    end

    public function FilteringIterator:iterator(): Iterator<T>
        return self
    end

    public function FilteringIterator:next(): Iteration<T>
        for value in self.source do
            if self.predicate(value) then
                return Iteration.Item(value)
            end
        end
        return Iteration.End
    end
end

private class TakingIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private remaining: Int

    public function TakingIterator.new(source: Iterator<T>, remaining: Int): TakingIterator<T>
        return TakingIterator { source = source, remaining = remaining }
    end

    public function TakingIterator:iterator(): Iterator<T>
        return self
    end

    public function TakingIterator:next(): Iteration<T>
        if self.remaining <= 0 then
            return Iteration.End
        end
        for value in self.source do
            self.remaining -= 1
            return Iteration.Item(value)
        end
        self.remaining = 0
        return Iteration.End
    end
end

private class DroppingIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private remaining: Int

    public function DroppingIterator.new(source: Iterator<T>, remaining: Int): DroppingIterator<T>
        return DroppingIterator { source = source, remaining = remaining }
    end

    public function DroppingIterator:iterator(): Iterator<T>
        return self
    end

    public function DroppingIterator:next(): Iteration<T>
        for value in self.source do
            if self.remaining > 0 then
                self.remaining -= 1
            else
                return Iteration.Item(value)
            end
        end
        self.remaining = 0
        return Iteration.End
    end
end

private class TakingWhileIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private predicate: function(value: T): Boolean
    private finished: Boolean

    public function TakingWhileIterator.new(source: Iterator<T>, predicate: function(value: T): Boolean): TakingWhileIterator<T>
        return TakingWhileIterator { source = source, predicate = predicate, finished = false }
    end

    public function TakingWhileIterator:iterator(): Iterator<T>
        return self
    end

    public function TakingWhileIterator:next(): Iteration<T>
        if self.finished then
            return Iteration.End
        end
        for value in self.source do
            if self.predicate(value) then
                return Iteration.Item(value)
            end
            self.finished = true
            return Iteration.End
        end
        self.finished = true
        return Iteration.End
    end
end

private class DroppingWhileIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private predicate: function(value: T): Boolean
    private dropping: Boolean

    public function DroppingWhileIterator.new(source: Iterator<T>, predicate: function(value: T): Boolean): DroppingWhileIterator<T>
        return DroppingWhileIterator { source = source, predicate = predicate, dropping = true }
    end

    public function DroppingWhileIterator:iterator(): Iterator<T>
        return self
    end

    public function DroppingWhileIterator:next(): Iteration<T>
        for value in self.source do
            if not self.dropping or not self.predicate(value) then
                self.dropping = false
                return Iteration.Item(value)
            end
        end
        self.dropping = false
        return Iteration.End
    end
end

private class ConcatenatingIterator<T> implements Iterator<T>
    private first: Iterator<T>
    private second: Iterator<T>
    private firstComplete: Boolean

    public function ConcatenatingIterator.new(first: Iterator<T>, second: Iterator<T>): ConcatenatingIterator<T>
        return ConcatenatingIterator { first = first, second = second, firstComplete = false }
    end

    public function ConcatenatingIterator:iterator(): Iterator<T>
        return self
    end

    public function ConcatenatingIterator:next(): Iteration<T>
        if not self.firstComplete then
            for value in self.first do
                return Iteration.Item(value)
            end
            self.firstComplete = true
        end
        for value in self.second do
            return Iteration.Item(value)
        end
        return Iteration.End
    end
end

private class AppendingIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private value: T
    private pending: Boolean
    private sourceComplete: Boolean

    public function AppendingIterator.new(source: Iterator<T>, value: T): AppendingIterator<T>
        return AppendingIterator { source = source, value = value, pending = true, sourceComplete = false }
    end

    public function AppendingIterator:iterator(): Iterator<T>
        return self
    end

    public function AppendingIterator:next(): Iteration<T>
        if not self.sourceComplete then
            for value in self.source do
                return Iteration.Item(value)
            end
            self.sourceComplete = true
        end
        if self.pending then
            self.pending = false
            return Iteration.Item(self.value)
        end
        return Iteration.End
    end
end

private class PrependingIterator<T> implements Iterator<T>
    private source: Iterator<T>
    private value: T
    private pending: Boolean
    private finished: Boolean

    public function PrependingIterator.new(source: Iterator<T>, value: T): PrependingIterator<T>
        return PrependingIterator { source = source, value = value, pending = true, finished = false }
    end

    public function PrependingIterator:iterator(): Iterator<T>
        return self
    end

    public function PrependingIterator:next(): Iteration<T>
        if self.pending then
            self.pending = false
            return Iteration.Item(self.value)
        end
        if self.finished then
            return Iteration.End
        end
        for value in self.source do
            return Iteration.Item(value)
        end
        self.finished = true
        return Iteration.End
    end
end

private class ScanningIterator<T, TState> implements Iterator<TState>
    private source: Iterator<T>
    private state: TState
    private combine: function(state: TState, value: T): TState
    private finished: Boolean

    public function ScanningIterator.new(source: Iterator<T>, initial: TState, combine: function(state: TState, value: T): TState): ScanningIterator<T, TState>
        return ScanningIterator { source = source, state = initial, combine = combine, finished = false }
    end

    public function ScanningIterator:iterator(): Iterator<TState>
        return self
    end

    public function ScanningIterator:next(): Iteration<TState>
        if self.finished then
            return Iteration.End
        end
        for value in self.source do
            self.state = self.combine(self.state, value)
            return Iteration.Item(self.state)
        end
        self.finished = true
        return Iteration.End
    end
end

--- <summary>
--- Creates a lazy single-pass iterator that transforms source items.
--- </summary>
---
--- <typeparam name="T">
--- The source item type.
--- </typeparam>
---
--- <typeparam name="TSource">
--- The exact statically iterable source type.
--- </typeparam>
---
--- <typeparam name="U">
--- The transformed item type.
--- </typeparam>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="transform">
--- The function called once for each requested item.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <remarks>
--- Iteration is lazy, preserves source order, and uses statically resolved protocol and function calls.
--- </remarks>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; source iterator acquisition retains its documented cost.
--- Does not materialize source items.
--- </allocation>
---
--- <example>
--- <code language="pop" test="true">
--- private function mapExample(): Int
---     local values: {Int} = {1, 2, 3}
---     local doubled = Sequence.map(values, function(value: Int): Int
---         return value * 2
---     end)
---     return List.get(Sequence.collect(doubled), 2)
--- end
--- </code>
--- </example>
public function map<T, TSource: Iterable<T>, U>(
    source: TSource,
    transform: function(value: T): U
): Iterator<U>
    local iterator = MappingIterator.new(source:iterator(), transform)
    return iterator
end

--- <summary>
--- Creates a lazy single-pass iterator that retains matching items.
--- </summary>
---
--- <typeparam name="T">
--- The source and result item type.
--- </typeparam>
---
--- <typeparam name="TSource">
--- The exact statically iterable source type.
--- </typeparam>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called at most once per examined item.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <remarks>
--- Iteration is lazy, stable in source order, and never performs runtime member lookup.
--- </remarks>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; source iterator acquisition retains its documented cost.
--- Does not materialize source items.
--- </allocation>
---
--- <example>
--- <code language="pop" test="true">
--- private function filterExample(): Int
---     local values: {Int} = {1, 2, 3, 4}
---     local even = Sequence.filter(values, function(value: Int): Boolean
---         return value % 2 == 0
---     end)
---     return List.length(Sequence.collect(even))
--- end
--- </code>
--- </example>
public function filter<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Iterator<T>
    local iterator = FilteringIterator.new(source:iterator(), predicate)
    return iterator
end

--- <summary>
--- Creates a lazy iterator limited to a maximum number of source items.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="count">
--- The maximum number of items, with nonpositive values treated as zero.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; source iterator acquisition retains its documented cost.
--- Does not materialize source items.
--- </allocation>
public function take<T, TSource: Iterable<T>>(source: TSource, count: Int): Iterator<T>
    local remaining = count
    if remaining < 0 then
        remaining = 0
    end
    local iterator = TakingIterator.new(source:iterator(), remaining)
    return iterator
end

--- <summary>
--- Creates a lazy iterator that discards a bounded source prefix.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="count">
--- The maximum number of discarded items, with nonpositive values treated as zero.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; source iterator acquisition retains its documented cost.
--- Does not materialize source items.
--- </allocation>
public function drop<T, TSource: Iterable<T>>(source: TSource, count: Int): Iterator<T>
    local remaining = count
    if remaining < 0 then
        remaining = 0
    end
    local iterator = DroppingIterator.new(source:iterator(), remaining)
    return iterator
end

--- <summary>
--- Creates a lazy iterator over the longest matching source prefix.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called until the first false result.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; source iterator acquisition retains its documented cost.
--- Does not materialize source items.
--- </allocation>
public function takeWhile<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Iterator<T>
    local iterator = TakingWhileIterator.new(source:iterator(), predicate)
    return iterator
end

--- <summary>
--- Creates a lazy iterator that discards the longest matching source prefix.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called until the first false result.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; source iterator acquisition retains its documented cost.
--- Does not materialize source items.
--- </allocation>
public function dropWhile<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Iterator<T>
    local iterator = DroppingWhileIterator.new(source:iterator(), predicate)
    return iterator
end

--- <summary>
--- Creates a lazy iterator that traverses two sources in order.
--- </summary>
---
--- <param name="first">
--- The source traversed first.
--- </param>
---
--- <param name="second">
--- The source traversed after the first is exhausted.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object; both source iterator acquisitions retain their documented costs.
--- Does not materialize source items.
--- </allocation>
public function concat<T, TFirst: Iterable<T>, TSecond: Iterable<T>>(
    first: TFirst,
    second: TSecond
): Iterator<T>
    local iterator = ConcatenatingIterator.new(first:iterator(), second:iterator())
    return iterator
end

--- <summary>
--- Consumes a sequence from left to right into one state value.
--- </summary>
---
--- <typeparam name="T">
--- The source item type.
--- </typeparam>
---
--- <typeparam name="TSource">
--- The exact statically iterable source type.
--- </typeparam>
---
--- <typeparam name="TState">
--- The accumulated state type.
--- </typeparam>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="initial">
--- The initial state.
--- </param>
---
--- <param name="combine">
--- The function called once for each item in order.
--- </param>
---
--- <returns>
--- The final state.
--- </returns>
---
--- <remarks>
--- Consumption is eager, single-pass, and uses statically resolved protocol and function calls.
--- </remarks>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
---
--- <example>
--- <code language="pop" test="true">
--- private function foldExample(): Int
---     local values: {Int} = {1, 2, 3}
---     return Sequence.fold(values, 0, function(total: Int, value: Int): Int
---         return total + value
---     end)
--- end
--- </code>
--- </example>
public function fold<T, TSource: Iterable<T>, TState>(
    source: TSource,
    initial: TState,
    combine: function(state: TState, value: T): TState
): TState
    local state = initial
    for value in source do
        state = combine(state, value)
    end
    return state
end

--- <summary>
--- Consumes a sequence into a new growable list in source order.
--- </summary>
---
--- <typeparam name="T">
--- The source and collected item type.
--- </typeparam>
---
--- <typeparam name="TSource">
--- The exact statically iterable source type.
--- </typeparam>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <returns>
--- A newly allocated list containing every source item.
--- </returns>
---
--- <remarks>
--- Consumption is eager and materializes every item in stable source order.
--- </remarks>
---
--- <complexity time="O(n)" space="O(n)"/>
---
--- <allocation>
--- Allocates and grows one list containing the source items.
--- </allocation>
---
--- <example>
--- <code language="pop" test="true">
--- private function collectExample(): Int
---     local values: {Int} = {4, 5, 6}
---     local collected = Sequence.collect(values)
---     return List.get(collected, 3)
--- end
--- </code>
--- </example>
public function collect<T, TSource: Iterable<T>>(source: TSource): List<T>
    local values = List.create<<T>>()
    for value in source do
        List.add(values, value)
    end
    return values
end

--- <summary>
--- Tests whether at least one source item satisfies a predicate.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called in order until it returns true.
--- </param>
---
--- <returns>
--- True at the first matching item; otherwise false.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function any<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Boolean
    for value in source do
        if predicate(value) then
            return true
        end
    end
    return false
end

--- <summary>
--- Tests whether every source item satisfies a predicate.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called in order until it returns false.
--- </param>
---
--- <returns>
--- False at the first nonmatching item; otherwise true.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function all<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Boolean
    for value in source do
        if not predicate(value) then
            return false
        end
    end
    return true
end

--- <summary>
--- Counts every item in a source using checked integer arithmetic.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <returns>
--- The number of source items.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function count<T, TSource: Iterable<T>>(source: TSource): Int
    local total = 0
    for value in source do
        total += 1
    end
    return total
end

--- <summary>
--- Tests whether a source contains no remaining items.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <returns>
--- True when the source is exhausted; otherwise false.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function isEmpty<T, TSource: Iterable<T>>(source: TSource): Boolean
    for value in source do
        return false
    end
    return true
end

--- <summary>
--- Returns the first remaining item or an explicit fallback.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="fallback">
--- The value returned when the source is empty.
--- </param>
---
--- <returns>
--- The first item, or the fallback when the source is empty.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function firstOr<T, TSource: Iterable<T>>(source: TSource, fallback: T): T
    for value in source do
        return value
    end
    return fallback
end

--- <summary>
--- Returns the last remaining item or an explicit fallback.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="fallback">
--- The value returned when the source is empty.
--- </param>
---
--- <returns>
--- The last item, or the fallback when the source is empty.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function lastOr<T, TSource: Iterable<T>>(source: TSource, fallback: T): T
    local result = fallback
    for value in source do
        result = value
    end
    return result
end

--- <summary>
--- Calls an action once for every source item in order.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="action">
--- The function called for each item.
--- </param>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function each<T, TSource: Iterable<T>>(
    source: TSource,
    action: function(value: T)
)
    for value in source do
        action(value)
    end
end

--- <summary>
--- Tests whether no source item satisfies a predicate.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called in order until it returns true.
--- </param>
---
--- <returns>
--- False at the first matching item; otherwise true.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function none<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Boolean
    for value in source do
        if predicate(value) then
            return false
        end
    end
    return true
end

--- <summary>
--- Counts source items that satisfy a predicate.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called once for each item.
--- </param>
---
--- <returns>
--- The number of matching items.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function countWhere<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean
): Int
    local total = 0
    for value in source do
        if predicate(value) then
            total += 1
        end
    end
    return total
end

--- <summary>
--- Adds every integer in source order using checked arithmetic.
--- </summary>
---
--- <typeparam name="TSource">
--- The exact statically iterable integer source type.
--- </typeparam>
---
--- <param name="source">
--- The integer source.
--- </param>
---
--- <returns>
--- The checked sum, or zero when the source is empty.
--- </returns>
---
--- <remarks>
--- Evaluation is eager, single-pass, and left to right.
--- </remarks>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function sum<TSource: Iterable<Int>>(source: TSource): Int
    local total = 0
    for value in source do
        total += value
    end
    return total
end

--- <summary>
--- Multiplies every integer in source order using checked arithmetic.
--- </summary>
---
--- <typeparam name="TSource">
--- The exact statically iterable integer source type.
--- </typeparam>
---
--- <param name="source">
--- The integer source.
--- </param>
---
--- <returns>
--- The checked product, or one when the source is empty.
--- </returns>
---
--- <remarks>
--- Evaluation is eager, single-pass, and left to right.
--- </remarks>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function product<TSource: Iterable<Int>>(source: TSource): Int
    local result = 1
    for value in source do
        result *= value
    end
    return result
end

--- <summary>
--- Returns the least integer or an explicit fallback for an empty source.
--- </summary>
---
--- <typeparam name="TSource">
--- The exact statically iterable integer source type.
--- </typeparam>
---
--- <param name="source">
--- The integer source.
--- </param>
---
--- <param name="fallback">
--- The value returned only when the source is empty.
--- </param>
---
--- <returns>
--- The least source item, or the fallback when empty.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function minOr<TSource: Iterable<Int>>(source: TSource, fallback: Int): Int
    local result = fallback
    local found = false
    for value in source do
        if not found or value < result then
            result = value
            found = true
        end
    end
    return result
end

--- <summary>
--- Returns the greatest integer or an explicit fallback for an empty source.
--- </summary>
---
--- <typeparam name="TSource">
--- The exact statically iterable integer source type.
--- </typeparam>
---
--- <param name="source">
--- The integer source.
--- </param>
---
--- <param name="fallback">
--- The value returned only when the source is empty.
--- </param>
---
--- <returns>
--- The greatest source item, or the fallback when empty.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function maxOr<TSource: Iterable<Int>>(source: TSource, fallback: Int): Int
    local result = fallback
    local found = false
    for value in source do
        if not found or value > result then
            result = value
            found = true
        end
    end
    return result
end

--- <summary>
--- Returns the first matching item or an explicit fallback.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called in order until it returns true.
--- </param>
---
--- <param name="fallback">
--- The value returned when no item matches.
--- </param>
---
--- <returns>
--- The first matching item, or the fallback when none matches.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function findOr<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean,
    fallback: T
): T
    for value in source do
        if predicate(value) then
            return value
        end
    end
    return fallback
end

--- <summary>
--- Returns the one-based index of the first matching item or a fallback.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="predicate">
--- The function called in order until it returns true.
--- </param>
---
--- <param name="fallback">
--- The value returned when no item matches.
--- </param>
---
--- <returns>
--- The checked one-based index of the first match, or the fallback.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function indexOr<T, TSource: Iterable<T>>(
    source: TSource,
    predicate: function(value: T): Boolean,
    fallback: Int
): Int
    local index = 1
    for value in source do
        if predicate(value) then
            return index
        end
        index += 1
    end
    return fallback
end

--- <summary>
--- Adds projected integer values using checked arithmetic.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="select">
--- The integer projection called once per item.
--- </param>
---
--- <returns>
--- The checked projected sum, or zero for an empty source.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function sumBy<T, TSource: Iterable<T>>(
    source: TSource,
    select: function(value: T): Int
): Int
    local total = 0
    for value in source do
        total += select(value)
    end
    return total
end

--- <summary>
--- Multiplies projected integer values using checked arithmetic.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="select">
--- The integer projection called once per item.
--- </param>
---
--- <returns>
--- The checked projected product, or one for an empty source.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function productBy<T, TSource: Iterable<T>>(
    source: TSource,
    select: function(value: T): Int
): Int
    local result = 1
    for value in source do
        result *= select(value)
    end
    return result
end

--- <summary>
--- Returns the first item with the least projected integer key.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="select">
--- The integer projection called exactly once per visited item.
--- </param>
---
--- <param name="fallback">
--- The unprojected value returned only for an empty source.
--- </param>
---
--- <returns>
--- The first item with the least key, or the fallback when empty.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function minByOr<T, TSource: Iterable<T>>(
    source: TSource,
    select: function(value: T): Int,
    fallback: T
): T
    local result = fallback
    local resultKey = 0
    local found = false
    for value in source do
        local key = select(value)
        if not found or key < resultKey then
            result = value
            resultKey = key
            found = true
        end
    end
    return result
end

--- <summary>
--- Returns the first item with the greatest projected integer key.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="select">
--- The integer projection called exactly once per visited item.
--- </param>
---
--- <param name="fallback">
--- The unprojected value returned only for an empty source.
--- </param>
---
--- <returns>
--- The first item with the greatest key, or the fallback when empty.
--- </returns>
---
--- <complexity time="O(n)" space="O(1)"/>
---
--- <allocation>
--- Does not allocate storage of its own.
--- </allocation>
public function maxByOr<T, TSource: Iterable<T>>(
    source: TSource,
    select: function(value: T): Int,
    fallback: T
): T
    local result = fallback
    local resultKey = 0
    local found = false
    for value in source do
        local key = select(value)
        if not found or key > resultKey then
            result = value
            resultKey = key
            found = true
        end
    end
    return result
end

--- <summary>
--- Creates a lazy iterator that yields one value after the source.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="value">
--- The value yielded after the source is exhausted.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object and does not materialize source items.
--- </allocation>
public function append<T, TSource: Iterable<T>>(source: TSource, value: T): Iterator<T>
    local iterator = AppendingIterator.new(source:iterator(), value)
    return iterator
end

--- <summary>
--- Creates a lazy iterator that yields one value before the source.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="value">
--- The value yielded before the first source item.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator adapter.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object and does not materialize source items.
--- </allocation>
public function prepend<T, TSource: Iterable<T>>(source: TSource, value: T): Iterator<T>
    local iterator = PrependingIterator.new(source:iterator(), value)
    return iterator
end

--- <summary>
--- Creates a lazy iterator over successive accumulated states.
--- </summary>
---
--- <param name="source">
--- The statically iterable source.
--- </param>
---
--- <param name="initial">
--- The state used before the first source item.
--- </param>
---
--- <param name="combine">
--- The function called once for each requested source item.
--- </param>
---
--- <returns>
--- A newly allocated lazy iterator that omits the initial state itself.
--- </returns>
---
--- <complexity time="O(1)" space="O(1)"/>
---
--- <allocation>
--- Allocates one adapter-state object and does not materialize source items.
--- </allocation>
public function scan<T, TSource: Iterable<T>, TState>(
    source: TSource,
    initial: TState,
    combine: function(state: TState, value: T): TState
): Iterator<TState>
    local iterator = ScanningIterator.new(source:iterator(), initial, combine)
    return iterator
end
