namespace Main

using Pop.Sequence

private record Candidate
    id: Int
    selected: Boolean
end

private enum ReductionStep
    A
    B
    C
    AB
    ABC
    Invalid
end

private class CountingIterator implements Iterator<Int>
    private current: Int
    private calls: Int

    public function CountingIterator.new(start: Int): CountingIterator
        return CountingIterator { current = start, calls = 0 }
    end

    public function CountingIterator:iterator(): Iterator<Int>
        return self
    end

    public function CountingIterator:next(): Iteration<Int>
        self.calls += 1
        if self.current >= 3 then
            return Iteration.End
        end
        self.current += 1
        return Iteration.Item(self.current)
    end

    public function CountingIterator:callCount(): Int
        return self.calls
    end
end

private class CandidateIterator implements Iterator<Candidate>
    private values: {Candidate}
    private index: Int
    private calls: Int

    public function CandidateIterator.new(values: {Candidate}): CandidateIterator
        return CandidateIterator { values = values, index = 1, calls = 0 }
    end

    public function CandidateIterator:iterator(): Iterator<Candidate>
        return self
    end

    public function CandidateIterator:next(): Iteration<Candidate>
        self.calls += 1
        if self.index > Array.length(self.values) then
            return Iteration.End
        end
        local value = Array.get(self.values, self.index)
        self.index += 1
        return Iteration.Item(value)
    end

    public function CandidateIterator:callCount(): Int
        return self.calls
    end
end

private function main(): Int
    local invalidCounter = CountingIterator.new(0)
    local invalidSource: Iterator<Int> = invalidCounter
    if elementAtOr(invalidSource, 0, 9) ~= 9 or invalidCounter:callCount() ~= 0 then
        return 1
    end

    local indexedCounter = CountingIterator.new(0)
    local indexedSource: Iterator<Int> = indexedCounter
    if elementAtOr(indexedSource, 2, 9) ~= 2 or indexedCounter:callCount() ~= 2 then
        return 2
    end

    local first: Candidate = { id = 1, selected = true }
    local second: Candidate = { id = 2, selected = false }
    local third: Candidate = { id = 3, selected = true }
    local fourth: Candidate = { id = 4, selected = false }
    local fallback: Candidate = { id = 9, selected = false }
    local candidates: {Candidate} = {first, second, third, fourth}
    local emptyCandidates: {Candidate} = {}
    local singleCandidate: {Candidate} = {first}
    local emptyResult = elementAtOr(emptyCandidates, 1, fallback)
    local singleResult = elementAtOr(singleCandidate, 1, fallback)
    if emptyResult.id ~= 9 or singleResult.id ~= 1 then
        return 3
    end

    local findCounter = CandidateIterator.new(candidates)
    local findSource: Iterator<Candidate> = findCounter
    local found = findLastOr(findSource, function(value: Candidate): Boolean
        return value.selected
    end, fallback)
    local indexCounter = CandidateIterator.new(candidates)
    local indexSource: Iterator<Candidate> = indexCounter
    local foundIndex = indexLastOr(indexSource, function(value: Candidate): Boolean
        return value.selected
    end, 0)
    if found.id ~= 3 or foundIndex ~= 3 or findCounter:callCount() ~= 5 or indexCounter:callCount() ~= 5 then
        return 4
    end

    local missingFindCounter = CandidateIterator.new(candidates)
    local missingFindSource: Iterator<Candidate> = missingFindCounter
    local missing = findLastOr(missingFindSource, function(value: Candidate): Boolean
        return value.id == 8
    end, fallback)
    local missingIndexCounter = CandidateIterator.new(candidates)
    local missingIndexSource: Iterator<Candidate> = missingIndexCounter
    local missingIndex = indexLastOr(missingIndexSource, function(value: Candidate): Boolean
        return value.id == 8
    end, -1)
    if missing.id ~= 9 or missingIndex ~= -1 or missingFindCounter:callCount() ~= 5 or missingIndexCounter:callCount() ~= 5 then
        return 5
    end

    local secondCandidate = elementAtOr(candidates, 2, fallback)
    local missingCandidate = elementAtOr(candidates, 8, fallback)
    if secondCandidate.id ~= 2 or missingCandidate.id ~= 9 then
        return 6
    end

    local steps: {ReductionStep} = {ReductionStep.A, ReductionStep.B, ReductionStep.C}
    local reduced = reduceOr(steps, function(left: ReductionStep, right: ReductionStep): ReductionStep
        if left == ReductionStep.A and right == ReductionStep.B then
            return ReductionStep.AB
        end
        if left == ReductionStep.AB and right == ReductionStep.C then
            return ReductionStep.ABC
        end
        return ReductionStep.Invalid
    end, ReductionStep.Invalid)
    local empty: {ReductionStep} = {}
    local single: {ReductionStep} = {ReductionStep.B}
    if reduced ~= ReductionStep.ABC then
        return 7
    end
    if reduceOr(empty, function(left: ReductionStep, right: ReductionStep): ReductionStep
        return right
    end, ReductionStep.Invalid) ~= ReductionStep.Invalid then
        return 8
    end
    if reduceOr(single, function(left: ReductionStep, right: ReductionStep): ReductionStep
        return right
    end, ReductionStep.Invalid) ~= ReductionStep.B then
        return 9
    end
    return 0
end
